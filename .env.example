# Copier en .env pour docker-compose
# DATABASE_URL est défini dans docker-compose.yml pour les services

# Clé secrète JWT (obligatoire pour le login)
SECRET_KEY=healthaim-secret-key-dev-change-in-production

# Ports d'accès externes (optionnel)
# POSTGRES_PORT=127.0.0.1:5435   # port exposé pour PostgreSQL
# BACKEND_PORT=127.0.0.1:8089    # port exposé pour l'API
# FRONTEND_PORT=127.0.0.1:89    # port exposé pour le frontend Vue.js
# AIRFLOW_PORT=8080  # port exposé pour l'interface Airflow (0.0.0.0 par défaut)
# VITE_API_URL=http://localhost:8089  # URL du backend (pour le build frontend)
