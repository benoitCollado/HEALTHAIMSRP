# Adresse de connexion a la base de donnees PostgreSQL (Neon serverless)
# Recuperer depuis le dashboard Neon -> Connection Details
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require&channel_binding=require


# Cle secrete du backend
# Elle sert a signer et verifier les JWT (tokens de connexion)
# Elle doit rester SECRETE et ne jamais etre envoyee au client
# En production, cette cle doit etre longue, aleatoire et stockee uniquement ici
SECRET_KEY=


# Duree de validite du token JWT en minutes
# Ici : le token expire apres 30 minutes
# Apres expiration, l'utilisateur doit se reconnecter
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Prefixe public expose par le reverse proxy nginx
API_ROOT_PATH=/api

# Origines frontend autorisees par CORS, separees par des virgules.
# Mettre l'origine du site, sans /api ni slash final.
CORS_ALLOWED_ORIGINS=http://localhost:89,http://127.0.0.1:89,https://healthai.benoitcollado.com

# URL utilisee par le frontend pour joindre l'API
VITE_API_URL=/api


# Alertes email (erreurs 500) - laisser vide pour desactiver
# Pour Gmail : creer un mot de passe d'application sur myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=

# Alertes applicatives
# Les erreurs 5xx envoient un email si SMTP est configure.
# Un 403 isole n'envoie pas d'email. Une rafale de 403 pour le meme
# client/utilisateur declenche une alerte securite.
ERROR_ALERT_EMAIL_ENABLED=true
ERROR_ALERT_ON_403=true
ERROR_ALERT_403_THRESHOLD=5
ERROR_ALERT_403_WINDOW_SECONDS=300
ERROR_ALERT_403_COOLDOWN_SECONDS=300
ERROR_ALERT_EMAILS_IN_TESTS=false

# Anciennes variables encore supportees par le backend
EMAIL_USER=
EMAIL_PASS=


# Logs applicatifs du backend
LOG_DIR=logs


# Frontend (Vite) — URL complète de l'API, sans slash final
# Source unique : ce fichier (et .env copié pour la prod / le dev local)
# Build Docker : docker compose build frontend lit cette variable
# Tests Vitest : valeur de repli si .env absent (ex. CI)
VITE_API_URL=https://healthai.benoitcollado.com/api
VITE_AIRFLOW_UI_URL=http://localhost:8080


# Monitoring (docker compose -f docker-compose.monitoring.yml)
# GF_SECURITY_ADMIN_PASSWORD ne s'applique qu'au 1er demarrage Grafana.
# Si le mot de passe ne marche plus : scripts/reset-grafana-password.sh
GRAFANA_ADMIN_PASSWORD=
GRAFANA_PORT=127.0.0.1:3000
GRAFANA_ROOT_URL=http://127.0.0.1:3000
COMPOSE_NETWORK_NAME=healthaimsrp_health_net

# API mistrall
KEY_MISTRAL_API=
MISTRAL_MODEL=mistral-small-latest

# MinIO / S3 compatible storage
MINIO_ACCESS_KEY=healthai_app
MINIO_SECRET_KEY=CHANGE_ME_STRONG_PASSWORD_2026

MINIO_BUCKET=healthai-meal-photos

MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=127.0.0.1:9100

MINIO_PORT=127.0.0.1:9100
MINIO_CONSOLE_PORT=127.0.0.1:9101
