# Adresse de connexion a la base de donnees PostgreSQL (Neon serverless)
# Recuperer depuis le dashboard Neon -> Connection Details
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require&channel_binding=require


# Cle secrete du backend
# Elle sert a signer et verifier les JWT (tokens de connexion)
# Elle doit rester SECRETE et ne jamais etre envoyee au client
# En production, cette cle doit etre longue, aleatoire et stockee uniquement ici
SECRET_KEY=


# Duree de validite du token JWT en minutes
# Ici : le token expire apres 30 minutes
# Apres expiration, l'utilisateur doit se reconnecter
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Prefixe public expose par le reverse proxy nginx
API_ROOT_PATH=/api

# URL utilisee par le frontend pour joindre l'API
VITE_API_URL=/api


# Alertes email (erreurs 500) - laisser vide pour desactiver
# Pour Gmail : creer un mot de passe d'application sur myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=

# Anciennes variables encore supportees par le backend
EMAIL_USER=
EMAIL_PASS=


# Logs applicatifs du backend
LOG_DIR=logs
