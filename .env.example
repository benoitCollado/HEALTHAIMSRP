# Adresse de connexion à la base de données PostgreSQL (Neon serverless)
DATABASE_URL=postgresql://neondb_owner:npg_8PCUiRnyhIZ5@ep-late-mouse-alf0ci3t-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require


# Clé secrète du backend
# Elle sert à signer et vérifier les JWT (tokens de connexion)
# Elle doit rester SECRÈTE et ne jamais être envoyée au client
# En production, cette clé doit être longue, aléatoire et stockée uniquement ici
SECRET_KEY=


# Durée de validité du token JWT en minutes
# Ici : le token expire après 30 minutes
# Après expiration, l'utilisateur doit se reconnecter
ACCESS_TOKEN_EXPIRE_MINUTES=30
